# Supabase (optional — enables cross-device cloud sync + email login).
# Leave these blank/unset to run William as a local-only tracker.
#
# 1. Create a free project at https://supabase.com
# 2. Project Settings → API → copy the "Project URL" and the "anon public" key
# 3. Copy this file to `.env.local` and paste your values below
# 4. Run the SQL in SETUP-SUPABASE.md to create the `sync_stores` table

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Demo build (optional). Set to 1 ONLY on the shared/public deployment.
# Seeds the placeholder dataset and marks setup complete, so the root URL opens
# on a filled dashboard instead of the onboarding wizard. Leave unset locally so
# the real onboarding flow stays testable.
VITE_DEMO_MODE=
